<svg width="1200" height="600" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="valueGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F59E0B;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#D97706;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#B45309;stop-opacity:1" />
    </linearGradient>
    <filter id="valueGlow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  <rect width="1200" height="600" fill="url(#valueGrad)"/>
  <circle cx="150" cy="100" r="100" fill="rgba(255,255,255,0.1)" filter="url(#valueGlow)"/>
  <circle cx="1050" cy="480" r="130" fill="rgba(255,255,255,0.08)" filter="url(#valueGlow)"/>
  <circle cx="600" cy="300" r="75" fill="rgba(255,255,255,0.06)" filter="url(#valueGlow)"/>
  <text x="600" y="270" font-family="Inter, Arial, sans-serif" font-size="64" font-weight="900" text-anchor="middle" fill="white" letter-spacing="1">BUSINESS BUILT</text>
  <text x="600" y="350" font-family="Inter, Arial, sans-serif" font-size="64" font-weight="900" text-anchor="middle" fill="white" letter-spacing="1">FOR VALUE &amp; OPTIONS</text>
  <text x="600" y="450" font-family="Inter, Arial, sans-serif" font-size="24" text-anchor="middle" fill="rgba(255,255,255,0.9)">Reduce dependency. Increase resilience. Build optionality.</text>
</svg>
